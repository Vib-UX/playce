# Playce environment variables

# ── Privy ──────────────────────────────────────────────────────────────────
# App ID is public. With no app id set, Playce runs a polished "demo auth"
# mode (email -> mock embedded wallet) so the flow works out of the box.
# Get credentials at https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=

# App Secret is SERVER-ONLY (no NEXT_PUBLIC_ prefix). Used by /api/claim to
# verify the user's Privy access token before minting.
PRIVY_APP_SECRET=

# ── Onchain (Base Sepolia, chain 84532) ──────────────────────────────────────
# Deployed PlaycePass (ERC-721) address. When set, the check-in flow mints a
# real reward; otherwise it falls back to the mock mint.
NEXT_PUBLIC_PLAYCE_CONTRACT_ADDRESS=

# Server-only minter private key. The backend mints rewards to users from this
# wallet so check-ins are gasless for the user. Keep this secret.
MINTER_PRIVATE_KEY=

# Base Sepolia RPC endpoint.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Pinata / IPFS ────────────────────────────────────────────────────────────
# Server-only Pinata JWT (no NEXT_PUBLIC_ prefix). Used by /api/upload to pin the
# captured "moment" photo, and by /api/claim to pin the token metadata JSON.
# Create a key at https://app.pinata.cloud/developers/api-keys
PINATA_JWT=

# Public IPFS gateway base used to render pinned images in the browser.
# Pinata gives you a dedicated gateway (e.g. https://your-name.mypinata.cloud).
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud
