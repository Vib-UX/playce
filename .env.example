# Playces environment variables

# ── Contract verification (optional) ─────────────────────────────────────────
# Single Etherscan API v2 key works for Basescan, Arbiscan, and Etherscan.
# Used by `bash contracts/verify-all.sh` for explorer green checks.
# Sourcify verification works without this key.
# ETHERSCAN_API_KEY=

# ── Privy ──────────────────────────────────────────────────────────────────
# App ID is public. With no app id set, Playces runs a polished "demo auth"
# mode (email -> mock embedded wallet) so the flow works out of the box.
# Get credentials at https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=

# App Secret is SERVER-ONLY (no NEXT_PUBLIC_ prefix). Used by /api/claim to
# verify the user's Privy access token before minting.
PRIVY_APP_SECRET=

# ── Settlement chain ─────────────────────────────────────────────────────────
# App runtime: base (8453, default) | sepolia (11155111) | base-sepolia (84532)
# Privy/wagmi always expose all three; SETTLEMENT_CHAIN picks the active one.
NEXT_PUBLIC_SETTLEMENT_CHAIN=base
# SETTLEMENT_CHAIN=base

# Active chain contract addresses (used when SETTLEMENT_CHAIN matches):
NEXT_PUBLIC_PLAYCES_CONTRACT_ADDRESS=
STAKE_ESCROW_ADDRESS=
NEXT_PUBLIC_STAKE_ESCROW_ADDRESS=

# Other chain deployments (set by contracts/deploy-all.sh; app still on Sepolia):
# BASE_MAINNET_PLAYCES_CONTRACT_ADDRESS=
# BASE_MAINNET_STAKE_ESCROW_ADDRESS=
# BASE_SEPOLIA_PLAYCES_CONTRACT_ADDRESS=
# BASE_SEPOLIA_STAKE_ESCROW_ADDRESS=

# Server-only minter private key. The backend mints rewards to users from this
# wallet so check-ins are gasless for the user. Keep this secret.
MINTER_PRIVATE_KEY=

# RPC endpoints (active chain picks via SETTLEMENT_CHAIN).
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org
# NEXT_PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# ── ENS subname tickets (ENSv2 on Sepolia) ──────────────────────────────────
# Issues an event-scoped subname (e.g. alice-ethglobal-nyc.playce.eth) to each
# attendee as their ticket. The backend signs with MINTER_PRIVATE_KEY, which must
# own the parent name (playce.eth) in the registry below. Resolution is handled
# automatically by viem's ENSv2 Universal Resolver on Sepolia.
ENS_SUBNAME_ENABLED=false
# Durin-style L2 registry (mints subnames via register(...)) on Sepolia.
ENS_REGISTRY_ADDRESS=
# Resolver that stores addr/text records for the subnames.
ENS_RESOLVER_ADDRESS=
# Chain the registry/resolver live on (Ethereum Sepolia = 11155111).
ENS_CHAIN_ID=11155111
# Parent ENS name the subnames hang off of.
ENS_PARENT_NAME=playce.eth
# Ticket lifetime in days (expiry = now + this). Keepsake = a long value.
ENS_TICKET_DURATION_DAYS=365
# Client-side mirrors (read-only): gate the UI + resolve names in the browser.
NEXT_PUBLIC_ENS_ENABLED=false
NEXT_PUBLIC_ENS_PARENT_NAME=playce.eth
# NEXT_PUBLIC_SEPOLIA_RPC_URL is reused for client-side ENS reads (see above).

# ── Pinata / IPFS ────────────────────────────────────────────────────────────
# Server-only Pinata JWT (no NEXT_PUBLIC_ prefix). Used by /api/upload to pin the
# captured "moment" photo, and by /api/claim to pin the token metadata JSON.
# Create a key at https://app.pinata.cloud/developers/api-keys
PINATA_JWT=

# ── Blink / staking (production mainnet) ─────────────────────────────────────
# Merchant id from Blink registration (safe to expose in the client for SDK preload).
# Production and sandbox use separate merchants — see https://docs.blink.cash
MERCHANT_ID=
NEXT_PUBLIC_BLINK_MERCHANT_ID=
# Omit or set to production (default). Only set sandbox for local testnet dev.
# NEXT_PUBLIC_BLINK_ENVIRONMENT=production
# Dev/test only: keep the stake UI but skip the real Blink deposit + on-chain
# USDC credit (auto-marks the seat as staked). Never enable in production.
# NEXT_PUBLIC_BLINK_DEV_MOCK_STAKE=true

# Server-only ECDSA P-256 private key PEM (use \n for line breaks in .env.local).
MERCHANT_PRIVATE_KEY=

# Optional: submit a new Blink merchant application
# BLINK_REGISTRATION_EMAIL=
# BLINK_REGISTRATION_DOMAIN=playces.fun

# Public IPFS gateway base used to render pinned images in the browser.
# Pinata gives you a dedicated gateway (e.g. https://your-name.mypinata.cloud).
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# ── Chainlink CCIP (cross-chain proof of presence) ───────────────────────────
# When CCIP_ENABLED=true, /api/proof dispatches a CCIP message from the SOURCE
# chain's ProofSender so the proof-of-presence NFT mints on the DEST chain's
# ProofReceiverPass (based on chain-battle outcomes). Populated by
# `contracts/deploy-ccip.sh`. Leave disabled to use the direct/mock mint path.
# The backend signs the CCIP send with MINTER_PRIVATE_KEY (must hold SENDER_ROLE
# on ProofSender, which must be funded with LINK on the source chain for fees).
CCIP_ENABLED=false
# Source = where chain battles settle; Dest = where the proof is minted.
CCIP_SOURCE_CHAIN=arbitrum-sepolia
CCIP_DEST_CHAIN=sepolia
PROOF_SENDER_ADDRESS=
PROOF_RECEIVER_ADDRESS=
# CCIP router + LINK token on the SOURCE chain (Arbitrum Sepolia defaults shown):
CCIP_ROUTER_ADDRESS=0x2a9C5afB0d0e4BAb2BCdaE109EC4b0c4Be15a165
LINK_TOKEN_ADDRESS=0xb1D4538B4571d411F07960EF2838Ce337FE1E80E
# CCIP chain selector of the DEST chain (Ethereum Sepolia default shown):
CCIP_DEST_CHAIN_SELECTOR=16015286601757825753

# ── Chain-battle win badges (claimed via Privy) ──────────────────────────────
# A chain battle (winner repped Arbitrum or Ethereum) rewards the winner with a
# soulbound win badge on their repped chain, claimed via /api/reward/claim:
#   - Arbitrum-repped win -> DIRECT backend mint on Arbitrum Sepolia (PlaycesPass
#     at BADGE_ARBITRUM_ADDRESS, backend holds MINTER_ROLE).
#   - Ethereum-repped win  -> Chainlink CCIP, reusing PROOF_SENDER_ADDRESS
#     (Arbitrum Sepolia) -> PROOF_RECEIVER_ADDRESS (Ethereum Sepolia) above.
# Populated by `contracts/deploy-badge.sh` (+ `contracts/deploy-ccip.sh`).
WIN_BADGE_ENABLED=false
BADGE_ARBITRUM_ADDRESS=
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
# NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# ── Chain-battle pot settlement (Base mainnet) ───────────────────────────────
# The USDC pot is settled on the Base-mainnet StakeEscrow when the winner claims.
# Defaults to STAKE_ESCROW_ADDRESS; override here if the app runs on a testnet
# while the pot lives on Base mainnet.
# BASE_MAINNET_STAKE_ESCROW_ADDRESS=0x01D514432b6694D8260bbA0fc2af3Cf327020823
