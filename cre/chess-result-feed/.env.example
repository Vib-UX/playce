# Local secrets for `cre workflow simulate`. Copy to .env and fill in as needed.
#
# Anonymous Lichess reads need nothing here. Only set a token if you switch to
# authenticated Lichess calls (and uncomment LICHESS_TOKEN in secrets.yaml +
# main.ts).
# LICHESS_TOKEN=lip_xxx

# CRE platform credentials are managed by the `cre` CLI login, not this file.
